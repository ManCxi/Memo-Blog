# ==============================
# 应用配置
# ==============================
# 端口配置
PORT=3000
# 运行环境
NODE_ENV=development
# 会话密钥（生产环境请随机生成，保持足够长）
SESSION_SECRET=your-session-secret-key-change-this
# API JWT 密钥
JWT_SECRET=your-jwt-secret-key-change-this

# ==============================
# 数据库配置（三选一）
# ==============================

# ① SQLite 模式（开发/无数据库环境，默认）
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# ② MySQL 模式（生产推荐）
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=blog
# DB_USER=root
# DB_PASSWORD=123456

# ③ PostgreSQL 模式 未测试是否存在问题
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=blog
# DB_USER=postgres
# DB_PASSWORD=123456

# ==============================
# Redis 配置
# ==============================
# 设为 false 可完全禁用 Redis（Session 改用内存存储，缓存全部跳过）
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==============================
# 博客站点信息
# ==============================
SITE_TITLE=Memo
SITE_DESCRIPTION=分享技术与生活
SITE_KEYWORDS=博客,技术,生活
