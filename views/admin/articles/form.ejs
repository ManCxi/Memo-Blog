<% const activePage='articles' %>
  <%- include('../partials/layout-head') %>
    <link rel="stylesheet" href="/libs/air-datepicker/air-datepicker.css">

    <% if (typeof error !=='undefined' && error) { %>
      <div class="flash flash-error">⚠️ <%= error %></div>
    <% } %>

    <form method="POST"
      action="<%= article && article.id ? `/admin/articles/${article.id}?_method=PUT` : '/admin/articles' %>"
      enctype="multipart/form-data" id="articleForm" class="article-form-root">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="article-edit-layout">
        <!-- Left: main editor -->
        <div class="article-editor-wrap">
          <!-- Title -->
          <div class="form-section title-section">
            <input type="text" name="title" class="form-title-input" placeholder="请输入文章标题…"
              value="<%= article ? article.title : '' %>" required>
          </div>

          <!-- Summary & Editor -->
          <div class="form-section editor-section">
            <div class="form-mb">
              <label class="form-label">文章摘要</label>
              <textarea name="summary" class="form-control article-summary-fixed"
                placeholder="简短描述文章内容（可选，不填则自动截取正文）"><%= article ? article.summary : '' %></textarea>
            </div>

            <!-- Editor -->
            <div class="editor-container-wrap">
              <label class="form-label editor-inner-label">文章内容
                <span class="text-tertiary">（Rich Text）</span></label>
              <!-- 工具栏 -->
              <div id="editor-toolbar" class="editor-toolbar-wrap"></div>
              <!-- 编辑区 -->
              <div id="editor-container" class="editor-content-area"></div>
              <!-- 隐藏的 textarea 用于提交表单 -->
              <textarea id="hiddenContent" name="content" style="display:none;"><%= article ? article.content : '' %></textarea>
            </div>
          </div>
        </div>

        <!-- Right: settings -->
        <div class="article-sidebar-wrap">
          <!-- Submit / Actions -->
          <div class="form-section">
            <div class="form-section-title">操作</div>
            <div class="d-flex gap-8 flex-wrap">
              <button type="submit" class="btn btn-primary flex-1 justify-center">
                🚀 <%= article && article.id ? '保存修改' : '发布文章' %>
              </button>
              <button type="submit" name="status" value="draft" class="btn btn-secondary flex-1 justify-center">
                💾 草稿
              </button>
            </div>
            <div class="d-flex gap-8 mt-16 flex-wrap">
              <button type="button" class="btn btn-secondary flex-1 justify-center" onclick="openPreviewModal()">👁 预览</button>
              <a href="/admin/articles" class="btn btn-danger flex-1 justify-center">✕ 取消</a>
            </div>
          </div>

          <!-- Publish settings -->
          <div class="form-section">
            <div class="form-section-title">发布设置</div>
            <div class="form-mb">
              <label class="form-label">发布状态</label>
              <select name="status" form="articleForm" class="form-control form-control-sm">
                <option value="published" <%=!article || article.status==='published' ? 'selected' : '' %>>✅ 已发布</option>
                <option value="draft" <%=article && article.status==='draft' ? 'selected' : '' %>>📄 草稿</option>
              </select>
            </div>
            <div class="form-mb">
              <label class="form-label">发布时间</label>
              <%
                function formatDateTime(date) {
                  if (!date) return '';
                  const d = new Date(date);
                  const z = d.getTimezoneOffset() * 60 * 1000;
                  const localDate = new Date(d.getTime() - z);
                  return localDate.toISOString().slice(0, 16);
                }
              %>
              <input type="text" id="publishedAtPicker" class="form-control form-control-sm">
              <input type="hidden" id="publishedAtValue" name="publishedAt"
                value="<%= formatDateTime(article ? (article.publishedAt || article.createdAt) : new Date()) %>">
            </div>
            <label class="checkbox-label-inline">
              <input type="checkbox" name="pinned" value="1" <%=article && article.pinned ? 'checked' : '' %>>
              📌 置顶文章
            </label>
          </div>

          <!-- Cover -->
          <div class="form-section">
            <div class="form-section-title">封面图片</div>
            <div class="d-flex flex-column gap-8">
              <input type="text" name="cover" id="coverUrl" class="form-control form-control-sm"
                placeholder="URL 或选择附件" value="<%= article ? article.cover : '' %>"
                oninput="updateCoverPreview(this.value)">
              <button type="button" class="btn btn-secondary btn-sm justify-center"
                onclick="openAttachmentPicker(url => { document.getElementById('coverUrl').value = url; updateCoverPreview(url); }, {accept:'image'})">🖼
                选择图片附件</button>
            </div>
            <div class="cover-preview-box" id="coverPreview">
              <% if (article && article.cover) { %>
                <img src="<%= article.cover %>" alt="封面">
              <% } else { %>
                暂无封面
              <% } %>
            </div>
          </div>

          <!-- Category -->
          <div class="form-section">
            <div class="form-section-title">文章分类</div>
            <% const selectedCategory = article ? categories.find(c => String(c.id) === String(article.CategoryId || '')) : null; %>
            <div class="category-select" id="categorySelect">
              <input type="hidden" name="CategoryId" form="articleForm" id="categoryIdInput" value="<%= article ? (article.CategoryId || '') : '' %>">
              <button type="button" class="category-select-trigger form-control form-control-sm" id="categorySelectTrigger" onclick="toggleCategoryDropdown(event)">
                <span id="categorySelectLabel"><%= selectedCategory ? selectedCategory.name : '不选分类' %></span>
                <span class="category-select-arrow">⌄</span>
              </button>
              <div class="category-select-menu" id="categorySelectMenu">
                <button type="button" class="category-option <%= selectedCategory ? '' : 'active' %>" data-value="" data-label="不选分类" onclick="selectCategoryOption(this)">不选分类</button>
                <% categories.forEach(cat => { %>
                  <button type="button" class="category-option <%= article && String(article.CategoryId) === String(cat.id) ? 'active' : '' %>" data-value="<%= cat.id %>" data-label="<%= cat.name %>" onclick="selectCategoryOption(this)"><%= cat.name %></button>
                <% }) %>
              </div>
            </div>
            <button type="button" class="btn btn-secondary btn-sm quick-add-btn" onclick="openAddCategoryModal()">+ 快速创建分类</button>
          </div>

          <!-- Tags -->
          <div class="form-section">
            <div class="form-section-title">文章标签</div>
            <div class="checkbox-group">
              <% tags.forEach(tag=> { %>
                <div class="checkbox-chip">
                  <input type="checkbox" name="tagIds" form="articleForm" id="tag_<%= tag.id %>"
                    value="<%= tag.id %>" <%=selectedTags.includes(tag.id) ? 'checked' : '' %>>
                  <label for="tag_<%= tag.id %>"># <%= tag.name %></label>
                </div>
              <% }) %>
            </div>
            <button type="button" class="btn btn-secondary btn-sm quick-add-btn" onclick="openAddTagModal()">+ 快速创建标签</button>
          </div>
        </div>
      </div>
    </form>

    <script src="/libs/air-datepicker/air-datepicker.js"></script>
    <script src="/js/admin/article-form.js"></script>

        <%- include('../partials/layout-foot') %>
