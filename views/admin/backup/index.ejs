<% const activePage = 'backup' %>
<%- include('../partials/layout-head') %>

<div class="page-header" style="max-width: 900px; margin-bottom: 24px;">
  <h1 class="page-title" style="margin: 0;">备份与恢复</h1>
  <p style="color: var(--text-tertiary); font-size: 13px; margin: 4px 0 0 0;">保障站点数据安全，支持多数据库数据的一键导出与灾难恢复。</p>
</div>

<div class="settings-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 24px; max-width: 900px; margin-bottom: 30px;">
  <!-- Backup Section -->
  <div class="card" style="background: var(--bg-surface); border-radius: 16px; border: 1px solid var(--border); padding: 24px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
    <div>
      <h3 style="margin: 0 0 12px 0; font-size: 16px; font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 8px;">
        <span>📥</span> 立即创建整站备份
      </h3>
      <p style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 20px;">
        备份将打包为一个 <strong>.zip 压缩包</strong>，包括：
      </p>
      <ul style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; padding-left: 20px; margin-bottom: 24px;">
        <li>数据库全部表结构数据（用户、文章、设置等）</li>
        <li>附件媒体库中所有上传的图片和实体文件（/uploads）</li>
        <li>生成跨数据库（SQLite/MySQL/Postgres）兼容备份</li>
      </ul>
    </div>
    <button type="button" class="btn btn-primary" onclick="triggerExport()" style="width: 100%; justify-content: center; padding: 12px; font-weight: 600; border-radius: 10px;">
      生成并下载备份文件
    </button>
  </div>

  <!-- Restore Section -->
  <div class="card" style="background: var(--bg-surface); border-radius: 16px; border: 1px solid var(--border); padding: 24px; box-shadow: var(--shadow-sm);">
    <h3 style="margin: 0 0 12px 0; font-size: 16px; font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 8px;">
      <span>📤</span> 从备份还原站点
    </h3>
    <p style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 12px;">
      上传之前下载的 <strong>.zip 备份包</strong> 即可一键恢复系统到对应状态。
    </p>

    <!-- Danger Alert -->
    <div style="background: rgba(239, 68, 68, 0.08); border: 1px dashed rgba(239, 68, 68, 0.3); border-radius: 10px; padding: 12px 16px; margin-bottom: 16px;">
      <p style="margin: 0 0 4px 0; font-size: 12px; font-weight: 700; color: #ef4444; display: flex; align-items: center; gap: 4px;">
        ⚠️ 高危操作警告
      </p>
      <ul style="margin: 0; padding-left: 16px; font-size: 11px; color: #b91c1c; line-height: 1.5;">
        <li>还原操作将<strong>彻底清空并覆盖</strong>现有的所有文章、设置与静态图片。</li>
        <li>恢复后，您的登录账号和密码将被重置为备份包里的密码！</li>
      </ul>
    </div>

    <!-- Upload Dropzone -->
    <div id="dropzone" onclick="document.getElementById('backupFile').click()" style="border: 2px dashed var(--border); border-radius: 12px; padding: 24px 16px; text-align: center; background: var(--bg-body); cursor: pointer; transition: all 0.2s; margin-bottom: 16px;">
      <div style="font-size: 28px; margin-bottom: 8px;">📂</div>
      <div style="font-size: 12px; font-weight: 600; color: var(--text-secondary);" id="fileNameLabel">点击选择 或 拖拽备份 ZIP 到这里</div>
      <div style="font-size: 11px; color: var(--text-tertiary); margin-top: 4px;">支持最大 200MB 的备份文件</div>
      <input type="file" id="backupFile" accept=".zip" style="display: none;" onchange="handleFileSelected(event)">
    </div>

    <!-- Checkbox Confirmation -->
    <label style="display: flex; align-items: flex-start; gap: 8px; margin-bottom: 16px; cursor: pointer; user-select: none;">
      <input type="checkbox" id="confirmCheckbox" style="margin-top: 3px;" onchange="toggleRestoreButton()">
      <span style="font-size: 12px; color: var(--text-secondary); line-height: 1.4;">
        我已确认并理解：执行还原会完全覆盖当前网站全部内容。
      </span>
    </label>

    <button type="button" id="restoreBtn" class="btn btn-danger" onclick="triggerRestore()" style="width: 100%; justify-content: center; padding: 12px; font-weight: 600; border-radius: 10px;">
      开始一键还原
    </button>
  </div>
</div>

<!-- Fullscreen Spinner Overlay -->
<div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px); z-index: 9999; justify-content: center; align-items: center; flex-direction: column;">
  <div style="border: 4px solid rgba(255, 255, 255, 0.2); border-left-color: #fff; width: 48px; height: 48px; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 16px;"></div>
  <p style="color: #fff; font-size: 15px; font-weight: 600; margin: 0;" id="loadingText">正在还原整站数据，请勿刷新或关闭页面...</p>
</div>

<style>
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  #dropzone:hover {
    border-color: var(--primary);
    background: rgba(255, 87, 34, 0.02);
  }

  @media (max-width: 768px) {
    .settings-grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }
    .settings-grid .card {
      padding: 16px !important;
    }
    #loadingOverlay p {
      font-size: 13px !important;
      padding: 0 20px;
      text-align: center;
    }
  }
</style>

<script>
let selectedFile = null;

function triggerExport() {
  window.location.href = '/admin/backup/export';
}

function handleFileSelected(event) {
  const file = event.target.files[0];
  if (file) {
    selectedFile = file;
    document.getElementById('fileNameLabel').innerHTML = `已选择：<strong>${file.name}</strong> (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
    toggleRestoreButton();
  }
}

// Drag & Drop Zone Init
const dropzone = document.getElementById('dropzone');
dropzone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropzone.style.borderColor = 'var(--primary)';
  dropzone.style.background = 'rgba(255, 87, 34, 0.05)';
});
dropzone.addEventListener('dragleave', () => {
  dropzone.style.borderColor = 'var(--border)';
  dropzone.style.background = 'var(--bg-body)';
});
dropzone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropzone.style.borderColor = 'var(--border)';
  dropzone.style.background = 'var(--bg-body)';
  const files = e.dataTransfer.files;
  if (files.length > 0 && files[0].name.endsWith('.zip')) {
    selectedFile = files[0];
    document.getElementById('fileNameLabel').innerHTML = `已选择：<strong>${files[0].name}</strong> (${(files[0].size / 1024 / 1024).toFixed(2)} MB)`;
    toggleRestoreButton();
  } else {
    showToast('只能接受 .zip 格式的备份包！', 'error');
  }
});

function toggleRestoreButton() {
  // 校验逻辑已移至 triggerRestore() 中，用 alert 提示
}

async function triggerRestore() {
  const checkbox = document.getElementById('confirmCheckbox');
  if (!selectedFile) {
    alert('请先选择要上传的备份 ZIP 文件！');
    return;
  }
  if (!checkbox.checked) {
    alert('请先勾选「我已确认并理解」复选框！');
    return;
  }

  if (!confirm('请再次确认：此操作将清空现有数据库和所有的静态上传图片。您是否完全确定？')) {
    return;
  }

  // Show loading modal
  const overlay = document.getElementById('loadingOverlay');
  overlay.style.display = 'flex';

  const formData = new FormData();
  formData.append('backup', selectedFile);
  formData.append('_csrf', '<%= csrfToken %>');

  try {
    const resp = await fetch('/admin/backup/import', {
      method: 'POST',
      body: formData
    });

    const result = await resp.json();
    overlay.style.display = 'none';

    if (result.ok) {
      alert('系统恢复成功！页面将自动刷新。');
      window.location.reload();
    } else {
      showToast(result.message || '恢复失败', 'error');
    }
  } catch (err) {
    overlay.style.display = 'none';
    showToast('网络请求失败：' + err.message, 'error');
  }
}
</script>

<%- include('../partials/layout-foot') %>
