  height: auto !important;
  max-height: calc(100vh - 32px) !important;
  width: 440px !important;
  max-width: calc(100% - 32px) !important;
  animation: drawer-slide-in 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both !important;
  border: 1px solid var(--surface-border) !important;
  box-shadow: var(--surface-shadow-2) !important;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

@media (max-width: 768px) {
  .drawer-modal {
    width: 100% !important;
    margin: 12px !important;
    max-width: calc(100% - 24px) !important;
    border-radius: 20px !important;
  }
  .modal-overlay {
    justify-content: center !important;
    align-items: flex-end !important;
  }
}
.drawer-modal .modal-body {
  min-height: 0;
  overflow-y: auto;
}
#mdPreview img {
  max-height: 260px;
  object-fit: contain;
}
</style>

<!-- 详情弹窗 (右侧抽屉) -->
<div class="modal-overlay" id="mediaDetailModal" style="display:none; justify-content: flex-end; align-items: center; padding: 0;" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal-box drawer-modal">
    <div class="modal-header">
      <h3 class="modal-title">附件详情</h3>
      <button class="modal-close" onclick="document.getElementById('mediaDetailModal').style.display='none'">×</button>
    </div>
    <div class="modal-body">
      <div id="mdPreview" style="margin-bottom:16px; text-align:center;"></div>
      <div class="form-grid" style="margin-bottom:16px; grid-template-columns: 1fr;">
        <div class="form-group" style="margin-bottom:8px;"><label class="form-label" style="display:inline-block;width:60px;">文件名</label><span id="mdFilename" class="text-secondary" style="font-weight:600;word-break:break-all;"></span></div>
        <div class="form-group" style="margin-bottom:8px;"><label class="form-label" style="display:inline-block;width:60px;">类型</label><span id="mdType" class="badge"></span></div>
        <div class="form-group" style="margin-bottom:8px;"><label class="form-label" style="display:inline-block;width:60px;">大小</label><span id="mdSize" class="text-tertiary"></span></div>
        <div class="form-group" style="margin-bottom:8px;"><label class="form-label" style="display:inline-block;width:60px;">时间</label><span id="mdTime" class="text-tertiary"></span></div>
      </div>
      <div class="form-group"><label class="form-label">URL 链接</label><div style="display:flex;gap:6px;"><input id="mdUrl" class="form-control form-control-sm" readonly><button class="btn btn-secondary btn-sm" onclick="copyFrom('mdUrl')">复制</button></div></div>
      <div class="form-group"><label class="form-label">完整链接</label><div style="display:flex;gap:6px;"><input id="mdFullUrl" class="form-control form-control-sm" readonly><button class="btn btn-secondary btn-sm" onclick="copyFrom('mdFullUrl')">复制</button></div></div>
      <div class="form-group"><label class="form-label">HTML 标签</label><div style="display:flex;gap:6px;"><input id="mdHtml" class="form-control form-control-sm" readonly><button class="btn btn-secondary btn-sm" onclick="copyFrom('mdHtml')">复制</button></div></div>
      <div class="form-group"><label class="form-label">Markdown</label><div style="display:flex;gap:6px;"><input id="mdMd" class="form-control form-control-sm" readonly><button class="btn btn-secondary btn-sm" onclick="copyFrom('mdMd')">复制</button></div></div>
    </div>
    <div class="modal-footer" style="display:flex; gap:10px;">
      <button class="btn btn-danger" id="mdDeleteBtn" style="flex:1;justify-content:center;">🗑 删除附件</button>
      <button class="btn btn-primary" onclick="document.getElementById('mediaDetailModal').style.display='none'" style="flex:1;justify-content:center;">完成关闭</button>
    </div>
  </div>
</div>

<%- include('../partials/layout-foot') %>
