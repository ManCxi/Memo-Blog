<%- include('../partials/layout-head') %>
<link rel="stylesheet" href="/libs/easymde/easymde.min.css">
<script src="/libs/easymde/easymde.min.js"></script>

<% if (typeof error !== 'undefined' && error) { %>
<div class="flash flash-error">⚠️ <%= error %></div>
<% } %>

<form method="POST"
  action="<%= page && page.id ? `/admin/pages/${page.id}` : '/admin/pages' %>"
  id="pageForm" class="article-form-root">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <!-- Top actions -->
  <div class="article-topbar">
    <div class="article-topbar-inner">
      <div class="article-topbar-title">
        <input type="text" name="title" class="form-title-input form-title-input-topbar"
          placeholder="请输入页面标题…"
          value="<%= page ? page.title : '' %>" required>
      </div>
      <div class="article-topbar-actions">
        <%
          let btn1Text = '🚀 发布页面';
          let btn1Status = 'published';
          let btn2Text = '📄 设为隐藏';
          let btn2Status = 'hidden';

          if (page && page.id) {
            if (page.status === 'published') {
              btn1Text = '💾 保存修改';
              btn1Status = 'published';
              btn2Text = '📄 设为隐藏';
              btn2Status = 'hidden';
            } else {
              btn1Text = '💾 保存修改';
              btn1Status = 'hidden';
              btn2Text = '🚀 发布页面';
              btn2Status = 'published';
            }
          }
        %>
        <button type="submit" name="status" value="<%= btn1Status %>" class="btn btn-primary btn-sm justify-center"><%= btn1Text %></button>
        <button type="submit" name="status" value="<%= btn2Status %>" class="btn btn-secondary btn-sm justify-center"><%= btn2Text %></button>
        <a href="/admin/pages" class="btn btn-danger btn-sm justify-center">✕ 取消</a>
        <button type="button" class="btn btn-secondary btn-sm justify-center" id="openPageSettingsBtn" onclick="openPageSettings()">⚙️ 页面设置</button>
      </div>
    </div>
  </div>

  <div class="article-edit-layout">
    <div class="article-editor-wrap">
      <div class="form-section editor-section">
        <div class="form-mb">
          <label class="form-label">编辑器模式</label>
          <div class="d-flex align-items-center gap-16">
            <label class="checkbox-label-inline m-0">
              <input type="radio" name="editorMode" value="html" <%= !page || (page.editorType === 'html' && !page.isHtmlCode) ? 'checked' : '' %> onchange="switchEditor('html')"> 富文本
            </label>
            <label class="checkbox-label-inline m-0">
              <input type="radio" name="editorMode" value="markdown" <%= page && page.editorType === 'markdown' ? 'checked' : '' %> onchange="switchEditor('markdown')"> Markdown
            </label>
            <label class="checkbox-label-inline m-0">
              <input type="radio" name="editorMode" value="raw" <%= page && page.isHtmlCode ? 'checked' : '' %> onchange="switchEditor('raw')"> HTML 代码
            </label>
            <button type="button" class="btn btn-secondary btn-sm <%= page && page.editorType === 'markdown' && !page.isHtmlCode ? '' : 'd-none' %>" id="importMdBtn" onclick="triggerMdImport()">📥 导入 MD</button>
            <input type="file" id="mdFileInput" style="display:none;" accept=".md" onchange="handleMdFile(this)">
          </div>
          <input type="hidden" name="isHtmlCode" id="isHtmlCodeInput" value="<%= page && page.isHtmlCode ? '1' : '0' %>">
          <input type="hidden" name="editorType" id="editorTypeInput" value="<%= page ? page.editorType : 'html' %>">
        </div>

        <div class="editor-container-wrap">
          <label class="form-label editor-inner-label">页面内容</label>
          <div id="wang-editor-area" class="<%= page && (page.editorType === 'markdown' || page.isHtmlCode) ? 'd-none' : '' %>">
            <div id="editor-toolbar" class="editor-toolbar-wrap"></div>
            <div id="editor-container" class="editor-content-area"></div>
          </div>
          <div id="markdown-editor-area" class="<%= !page || page.editorType === 'html' || page.isHtmlCode ? 'd-none' : '' %>">
            <textarea id="markdown-editor" class="markdown-textarea"></textarea>
          </div>
          <div id="raw-html-editor-area" class="<%= page && page.isHtmlCode ? '' : 'd-none' %>">
            <textarea id="raw-html-editor" class="form-control" style="font-family: Consolas, Monaco, monospace; font-size: 14px; min-height: 500px; resize: vertical; line-height: 1.5; background: #fafafa; color: #333;" placeholder="在此直接编写 HTML/CSS/JS 代码..."><%= page && page.isHtmlCode ? page.content : '' %></textarea>
          </div>
          <textarea id="hiddenContent" name="content" style="display:none;"><%= page ? page.content : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Settings drawer -->
    <div class="article-drawer-overlay" id="pageSettingsOverlay" onclick="closePageSettings()"></div>
    <aside class="article-settings-drawer" id="pageSettingsDrawer" aria-hidden="true" role="dialog" aria-label="页面设置">
      <div class="article-settings-drawer-head">
        <div class="article-settings-drawer-title">页面设置</div>
        <button type="button" class="btn btn-secondary btn-sm" onclick="closePageSettings()">关闭</button>
      </div>
      <div class="article-settings-drawer-body">
        <div class="article-sidebar-wrap">
          <div class="form-section">
            <div class="form-section-title">路径设置</div>
            <label class="form-label">自定义路径 (Slug)</label>
            <div class="d-flex align-items-center gap-8">
              <span style="color: var(--text-tertiary); font-size: 14px;">/p/</span>
              <input type="text" name="slug" class="form-control form-control-sm"
                placeholder="about-me"
                value="<%= page ? page.slug : '' %>" required>
            </div>
            <div class="settings-desc" style="margin-top: 8px;">页面 URL 将是：domain.com/p/your-slug</div>
          </div>
        </div>
      </div>
    </aside>
</form>

<script src="/libs/marked/marked.min.js"></script>
<script src="/libs/turndown/turndown.js"></script>
<script src="/js/admin/page-form.js"></script>
<script>
let easyMDE = null;

function refreshMarkdownEditorViewport() {
  if (!easyMDE || !easyMDE.codemirror) return;
  const cm = easyMDE.codemirror;
  if (typeof cm.setSize === 'function') cm.setSize(null, '100%');
  if (typeof cm.getWrapperElement === 'function') {
    const wrapper = cm.getWrapperElement();
    if (wrapper) {
      wrapper.style.height = '100%';
      wrapper.style.minHeight = '0';
    }
  }
  if (typeof cm.getScrollerElement === 'function') {
    const scroller = cm.getScrollerElement();
    if (scroller) {
      scroller.style.maxHeight = '100%';
      scroller.style.overflowY = 'auto';
      scroller.style.overflowX = 'auto';
    }
  }
  if (typeof cm.refresh === 'function') cm.refresh();
}

function syncEasyMDEFullscreenState(targetEditor) {
  const editor = targetEditor || easyMDE;
  if (!editor || !editor.codemirror) return;
  const cm = editor.codemirror;
  let isFullscreen = false;
  if (typeof cm.isFullScreen === 'function') {
    isFullscreen = !!cm.isFullScreen();
  } else if (typeof cm.getWrapperElement === 'function') {
    const wrapper = cm.getWrapperElement();
    isFullscreen = !!(wrapper && wrapper.classList.contains('CodeMirror-fullscreen'));
  }
  document.body.classList.toggle('editor-is-fullscreen', isFullscreen);
}

function initMarkdownEditor() {
  const textarea = document.getElementById('markdown-editor');
  if (!textarea) return;

  const hiddenContent = document.getElementById('hiddenContent');
  easyMDE = new EasyMDE({
    element: textarea,
    autoDownloadFontAwesome: false,
    spellChecker: false,
    placeholder: '在此输入 Markdown 内容...',
    status: false,
    autosave: { enabled: false },
    renderingConfig: {
      singleLineBreaks: false,
      codeSyntaxHighlighting: true,
    },
    initialValue: hiddenContent ? hiddenContent.value : '',
    minHeight: 'auto',
    toolbar: [
      { name: "bold", action: EasyMDE.toggleBold, className: "fa fa-bold", title: "加粗 (Ctrl-B)" },
      { name: "italic", action: EasyMDE.toggleItalic, className: "fa fa-italic", title: "斜体 (Ctrl-I)" },
      { name: "heading", action: EasyMDE.toggleHeadingSmaller, className: "fa fa-header", title: "标题 (Ctrl-H)" },
      "|",
      { name: "quote", action: EasyMDE.toggleBlockquote, className: "fa fa-quote-left", title: "引用 (Ctrl-')" },
      { name: "unordered-list", action: EasyMDE.toggleUnorderedList, className: "fa fa-list-ul", title: "无序列表 (Ctrl-L)" },
      { name: "ordered-list", action: EasyMDE.toggleOrderedList, className: "fa fa-list-ol", title: "有序列表 (Ctrl-Alt-L)" },
      "|",
      { name: "link", action: EasyMDE.drawLink, className: "fa fa-link", title: "创建链接 (Ctrl-K)" },
      { 
        name: "image", 
        action: function(editor) {
          if (typeof window.openAttachmentPicker === 'function') {
          window.openAttachmentPicker(function(targetUrl) {
            const targetEditor = editor || window.easyMDE;
            if (!targetEditor || !targetEditor.codemirror) {
              console.error('EasyMDE instance not found for insertion (Page)');
              return;
            }
            // Ensure editor is focused
            targetEditor.codemirror.focus();
            // Format URL
            const imageUrl = targetUrl.startsWith('http') || targetUrl.startsWith('/') ? targetUrl : '/' + targetUrl;
            // Insert at cursor using the underlying CodeMirror instance
            targetEditor.codemirror.replaceSelection(`![图片描述](${imageUrl})`);
            // Refresh to sync value
            targetEditor.codemirror.refresh();
          }, { accept: 'image' });
          } else {
            // Fallback to default if picker not found
            EasyMDE.drawImage(editor);
          }
        }, 
        className: "fa fa-picture-o", 
        title: "插入媒体库图片 (Ctrl-Alt-I)" 
      },
      { name: "table", action: EasyMDE.drawTable, className: "fa fa-table", title: "插入表格" },
      "|",
      { name: "preview", action: EasyMDE.togglePreview, className: "fa fa-eye no-disable", title: "实时预览 (Ctrl-P)" },
      { name: "side-by-side", action: EasyMDE.toggleSideBySide, className: "fa fa-columns no-disable no-mobile", title: "分栏预览 (F9)" },
      {
        name: "fullscreen",
        action(editor) {
          EasyMDE.toggleFullScreen(editor);
          setTimeout(() => syncEasyMDEFullscreenState(editor || easyMDE), 0);
        },
        className: "fa fa-arrows-alt no-disable no-mobile",
        title: "全屏模式 (F11)"
      },
      "|",
      { name: "guide", action: "https://www.markdownguide.org/basic-syntax/", className: "fa fa-question-circle", title: "Markdown 指南" }
    ],
  });

  if (easyMDE && easyMDE.codemirror && typeof easyMDE.codemirror.on === 'function') {
    easyMDE.codemirror.on('keydown', (_, event) => {
      if (event && (event.key === 'F11' || event.key === 'Escape')) {
        setTimeout(() => syncEasyMDEFullscreenState(easyMDE), 0);
      }
    });
  }

  easyMDE.codemirror.on('change', () => {
    if (getEditorType() === 'markdown' && hiddenContent) {
      hiddenContent.value = easyMDE.value();
    }
  });
  setTimeout(refreshMarkdownEditorViewport, 100);
}

function getEditorType() {
  const selected = document.querySelector('input[name="editorMode"]:checked');
  return selected ? selected.value : 'html';
}

let lastActiveMode = '<%= page && page.isHtmlCode ? "raw" : (page ? page.editorType : "html") %>';

function switchEditor(type) {
  const wangArea = document.getElementById('wang-editor-area');
  const mdArea = document.getElementById('markdown-editor-area');
  const rawArea = document.getElementById('raw-html-editor-area');
  const importBtn = document.getElementById('importMdBtn');
  const hiddenContent = document.getElementById('hiddenContent');
  const rawTextarea = document.getElementById('raw-html-editor');

  const isHtmlCodeInput = document.getElementById('isHtmlCodeInput');
  const editorTypeInput = document.getElementById('editorTypeInput');

  if (type === lastActiveMode) return;

  // 如果从 HTML 代码模式切出，进行安全警告
  if (lastActiveMode === 'raw') {
    if (!confirm('从 "HTML代码" 模式切换到其他编辑器可能会导致您编写的自定义 CSS/JS 脚本或复杂 HTML 结构丢失，确定要切换吗？')) {
      // 恢复单选钮选中状态
      document.querySelector(`input[name="editorMode"][value="raw"]`).checked = true;
      return;
    }
  }

  // 1. 同步当前编辑器内容到 hiddenContent
  if (lastActiveMode === 'html' && window.editor) {
    hiddenContent.value = window.editor.getHtml();
  } else if (lastActiveMode === 'markdown') {
    hiddenContent.value = easyMDE ? easyMDE.value() : document.getElementById('markdown-editor').value;
  } else if (lastActiveMode === 'raw' && rawTextarea) {
    hiddenContent.value = rawTextarea.value;
  }

  // 2. 执行数据转换 (仅限于 html ⇔ markdown)
  if (type === 'markdown' && lastActiveMode === 'html') {
    const TurndownService = window.TurndownService || window.Turndown;
    if (TurndownService) {
      const turndownService = new TurndownService({
        headingStyle: 'atx',
        hr: '---',
        bulletListMarker: '-',
        codeBlockStyle: 'fenced'
      });

      // Code block rule
      turndownService.addRule('codeblock', {
        filter: 'pre',
        replacement: function (content, node) {
          const codeElem = node.querySelector('code');
          const code = codeElem ? (codeElem.innerText || codeElem.textContent) : (node.innerText || node.textContent);
          let lang = '';
          if (codeElem) {
            const cls = codeElem.className || '';
            const match = cls.match(/language-(\w+)/);
            if (match) lang = match[1];
          }
          return '\n\n```' + lang + '\n' + code.trim() + '\n```\n\n';
        }
      });

      // Headings rule
      turndownService.addRule('headings', {
        filter: ['h1', 'h2', 'h3', 'h4', 'h5', 'h6'],
        replacement: function (content, node) {
          const level = node.nodeName.charAt(1);
          return '\n\n' + '#'.repeat(level) + ' ' + content.trim() + '\n\n';
        }
      });

      // Prepare HTML for Turndown
      let rawHtml = hiddenContent.value.replace(/&nbsp;/g, ' ');
      if (rawHtml.includes('&lt;') && !rawHtml.includes('<')) {
        const decoder = document.createElement('div');
        decoder.innerHTML = rawHtml;
        rawHtml = decoder.textContent;
      }

      const parser = new DOMParser();
      const doc = parser.parseFromString(rawHtml, 'text/html');
      
      let markdown = turndownService.turndown(doc.body);
      markdown = markdown.replace(/\n{3,}/g, '\n\n').trim();
      hiddenContent.value = markdown;
    }
  } else if (type === 'html' && lastActiveMode === 'markdown') {
    const Marked = window.marked;
    if (Marked) {
      const markdown = hiddenContent.value;
      const html = Marked.parse ? Marked.parse(markdown) : (typeof Marked === 'function' ? Marked(markdown) : markdown);
      hiddenContent.value = html.trim();
    }
  }

  // 3. UI Toggle and Final Sync
  if (type === 'markdown') {
    if (wangArea) wangArea.classList.add('d-none');
    if (mdArea) mdArea.classList.remove('d-none');
    if (rawArea) rawArea.classList.add('d-none');
    if (importBtn) importBtn.classList.remove('d-none');
    if (easyMDE) {
      easyMDE.value(hiddenContent.value);
      setTimeout(refreshMarkdownEditorViewport, 0);
    }
    else {
      const ta = document.getElementById('markdown-editor');
      if (ta) ta.value = hiddenContent.value;
    }
    isHtmlCodeInput.value = '0';
    editorTypeInput.value = 'markdown';
  } else if (type === 'html') {
    if (wangArea) wangArea.classList.remove('d-none');
    if (mdArea) mdArea.classList.add('d-none');
    if (rawArea) rawArea.classList.add('d-none');
    if (importBtn) importBtn.classList.add('d-none');
    if (window.editor) window.editor.setHtml(hiddenContent.value);
    isHtmlCodeInput.value = '0';
    editorTypeInput.value = 'html';
  } else if (type === 'raw') {
    if (wangArea) wangArea.classList.add('d-none');
    if (mdArea) mdArea.classList.add('d-none');
    if (rawArea) rawArea.classList.remove('d-none');
    if (importBtn) importBtn.classList.add('d-none');
    if (rawTextarea) rawTextarea.value = hiddenContent.value;
    isHtmlCodeInput.value = '1';
    editorTypeInput.value = 'html';
  }

  lastActiveMode = type;
}


function triggerMdImport() {
  document.getElementById('mdFileInput').click();
}

function handleMdFile(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    const content = e.target.result;
    if (easyMDE) {
      easyMDE.value(content);
      const hiddenContent = document.getElementById('hiddenContent');
      if (hiddenContent) hiddenContent.value = content;
    }
    input.value = '';
  };
  reader.readAsText(file);
}

document.addEventListener('DOMContentLoaded', () => {
  initMarkdownEditor();
  setTimeout(() => {
    if (!window.wangEditor) return;
    const { createEditor, createToolbar } = window.wangEditor;

    const editorConfig = {
      placeholder: '请输入页面内容...',
      MENU_CONF: {
        uploadImage: {
          customUpload(file, insertFn) {
            const fd = new FormData();
            fd.append('file', file);
            fetch('/admin/media/upload', {
              method: 'POST',
              headers: { 'X-CSRF-Token': '<%= csrfToken %>' },
              body: fd
            })
              .then(r => r.json())
              .then(d => {
                if (d.ok) insertFn(d.url, d.filename, d.url);
                else alert('上传失败: ' + d.message);
              })
              .catch(e => alert('上传出错: ' + e.message));
          }
        }
      }
    };

    const initialContent = document.getElementById('hiddenContent').value || '';
    const editor = createEditor({
      selector: '#editor-container',
      html: initialContent,
      config: editorConfig,
      mode: 'default',
    });

    editor.on('change', () => {
      if (getEditorType() === 'html') {
        document.getElementById('hiddenContent').value = editor.getHtml();
      }
    });

    // Register custom media library menu for WangEditor
    const { Boot } = window.wangEditor;
    class MediaLibraryMenu {
      constructor() {
        this.title = '从媒体库选择';
        this.iconSvg = '<svg viewBox="0 0 1024 1024"><path d="M928 160H96c-17.7 0-32 14.3-32 32v640c0 17.7 14.3 32 32 32h832c17.7 0 32-14.3 32-32V192c0-17.7-14.3-32-32-32zM153.8 809.1l170.9-204 90.9 90.9L642.7 444l227.5 315.1H153.8zM736 384c-44.2 0-80-35.8-80-80s35.8-80 80-80 80 35.8 80 80-35.8 80-80 80z"></path></svg>';
        this.tag = 'button';
      }
      getValue(editor) { return ''; }
      isActive(editor) { return false; }
      isDisabled(editor) { return false; }
      exec(editor, value) {
        if (typeof window.openAttachmentPicker === 'function') {
          window.openAttachmentPicker(url => {
            editor.restoreSelection();
            editor.insertNode({
              type: 'image',
              src: url,
              alt: '图片',
              style: { width: '100%' },
              children: [{ text: '' }]
            });
          }, { accept: 'image' });
        } else {
          alert('媒体库组件未加载');
        }
      }
    }
    try {
      Boot.registerMenu({
        key: 'mediaLibrary',
        factory() { return new MediaLibraryMenu(); }
      });
    } catch (e) {}

    createToolbar({
      editor,
      selector: '#editor-toolbar',
      config: {
        insertKeys: {
          index: 23,
          keys: ['mediaLibrary']
        }
      },
      mode: 'default',
    });

    window.editor = editor;

    document.getElementById('pageForm').addEventListener('submit', function() {
      const mode = getEditorType();
      if (mode === 'markdown' && easyMDE) {
        document.getElementById('hiddenContent').value = easyMDE.value();
      } else if (mode === 'html' && window.editor) {
        document.getElementById('hiddenContent').value = window.editor.getHtml();
      } else if (mode === 'raw') {
        const rawTextarea = document.getElementById('raw-html-editor');
        if (rawTextarea) {
          document.getElementById('hiddenContent').value = rawTextarea.value;
        }
      }
    });
  }, 100);
});
</script>

<%- include('../partials/layout-foot') %>
