<script>
// ── Theme toggle ──
function toggleTheme() {
  const html = document.documentElement;
  const current = html.getAttribute('data-theme') || 'light';
  const next = current === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
    btn.textContent = next === 'dark' ? '☀️' : '🌙';
  });
}
(function() {
  const theme = localStorage.getItem('theme') || 'light';
  document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
  });
})();

const __enhancedSelectCloseFns = [];
function closeAllEnhancedSelects() {
  __enhancedSelectCloseFns.forEach(fn => fn());
}
function initAdminSelects(root = document) {
  const scope = root && root.querySelectorAll ? root : document;
  const selects = scope.querySelectorAll('select.form-control:not([multiple]):not([data-native-select]):not([data-admin-select-enhanced])');
  selects.forEach(select => {
    select.dataset.adminSelectEnhanced = '1';
    const wrapper = document.createElement('div');
    wrapper.className = 'admin-select';
    if (select.classList.contains('form-control-sm')) {
      wrapper.classList.add('form-control-sm');
    }
    const inlineStyle = select.getAttribute('style');
    if (inlineStyle) {
      wrapper.setAttribute('style', inlineStyle);
    }
    if (select.style.width === 'auto') {
      wrapper.classList.add('native-width');
    }
    const trigger = document.createElement('button');
    trigger.type = 'button';
    trigger.className = 'form-control admin-select-trigger' + (select.classList.contains('form-control-sm') ? ' form-control-sm' : '');
    const label = document.createElement('span');
    const arrow = document.createElement('span');
    arrow.className = 'admin-select-arrow';
    arrow.textContent = '▾';
    trigger.appendChild(label);
    trigger.appendChild(arrow);
    const menu = document.createElement('div');
    menu.className = 'admin-select-menu';
    function syncFromSelect() {
      const selected = select.options[select.selectedIndex];
      label.textContent = selected ? selected.textContent.trim() : '';
      menu.querySelectorAll('.admin-select-option').forEach(btn => {
        const active = btn.dataset.value === select.value;
        btn.classList.toggle('active', active);
      });
    }
    function close() {
      wrapper.classList.remove('open');
    }
    __enhancedSelectCloseFns.push(close);
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = !wrapper.classList.contains('open');
      closeAllEnhancedSelects();
      if (willOpen) wrapper.classList.add('open');
    });
    Array.from(select.options).forEach(option => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'admin-select-option';
      btn.dataset.value = option.value;
      btn.textContent = option.textContent;
      if (option.disabled) {
        btn.classList.add('disabled');
      }
      btn.addEventListener('click', () => {
        if (option.disabled) return;
        select.value = option.value;
        select.dispatchEvent(new Event('change', { bubbles: true }));
        syncFromSelect();
        close();
      });
      menu.appendChild(btn);
    });
    select.addEventListener('change', syncFromSelect);
    const parent = select.parentNode;
    parent.insertBefore(wrapper, select);
    wrapper.appendChild(select);
    wrapper.appendChild(trigger);
    wrapper.appendChild(menu);
    select.style.display = 'none';
    syncFromSelect();
  });
}
document.addEventListener('click', closeAllEnhancedSelects);
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAllEnhancedSelects();
});
const __enhancedSelectObserver = new MutationObserver((mutations) => {
  let shouldInit = false;
  mutations.forEach(m => {
    if (m.type === 'childList' && m.addedNodes && m.addedNodes.length) shouldInit = true;
  });
  if (shouldInit) initAdminSelects(document);
});
if (document.body) {
  __enhancedSelectObserver.observe(document.body, { childList: true, subtree: true });
}
initAdminSelects(document);

// ── Sidebar / Drawer ──
const sidebar = document.getElementById('adminSidebar');
const overlay = document.getElementById('sidebarOverlay');

// 自动移除悬浮提示
setTimeout(() => {
  document.querySelectorAll('.floating-toast').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translate(-50%, -20px)';
    el.style.transition = 'all 0.3s ease';
    setTimeout(() => el.remove(), 300);
  });
}, 2000);

function openSidebar() {
  if (!sidebar || !overlay) return;
  sidebar.classList.add('mobile-open');
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  if (!sidebar || !overlay) return;
  sidebar.classList.remove('mobile-open');
  overlay.classList.remove('open');
  document.body.style.overflow = '';
}
function toggleSidebar() {
  if (sidebar && sidebar.classList.contains('mobile-open')) {
    closeSidebar();
  } else {
    openSidebar();
  }
}

// Close sidebar on Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeSidebar();
});

// ── Modal helpers ──
function openModal(id)  {
  const el = document.getElementById(id);
  if (el) { el.style.display = 'flex'; el.classList.add('open'); }
}
function closeModal(id) {
  const el = document.getElementById(id);
  // 必须用 none：admin.css 里 .modal-overlay 默认是 display:flex，清空 inline 会回到可见状态
  if (el) { el.style.display = 'none'; el.classList.remove('open'); }
}
// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', function(e) {
    if (e.target === this) { this.style.display = 'none'; this.classList.remove('open'); }
  });
});

// ── Toast helper ──
function showToast(msg, type = 'success') {
  const t = document.createElement('div');
  t.className = 'toast toast-' + type;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.style.opacity = '0', 2700);
  setTimeout(() => t.remove(), 3000);
}

function buildWebpName(name) {
  if (!name) return 'upload.webp';
  const idx = name.lastIndexOf('.');
  if (idx <= 0) return `${name}.webp`;
  return `${name.slice(0, idx)}.webp`;
}

function loadImageFile(file) {
  return new Promise((resolve, reject) => {
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => {
      URL.revokeObjectURL(url);
      resolve(img);
    };
    img.onerror = () => {
      URL.revokeObjectURL(url);
      reject(new Error('图片读取失败'));
    };
    img.src = url;
  });
}

function canvasToBlob(canvas, type, quality) {
  return new Promise(resolve => canvas.toBlob(resolve, type, quality));
}

async function compressImageBeforeUpload(file) {
  if (!file || !file.type || !file.type.startsWith('image/')) return file;
  const lower = (file.name || '').toLowerCase();
  if (lower.endsWith('.gif') || lower.endsWith('.svg')) return file;
  try {
    const img = await loadImageFile(file);
    const maxEdge = 2560;
    const ratio = Math.min(1, maxEdge / Math.max(img.width || 1, img.height || 1));
    const w = Math.max(1, Math.round((img.width || 1) * ratio));
    const h = Math.max(1, Math.round((img.height || 1) * ratio));
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d');
    if (!ctx) return file;
    ctx.drawImage(img, 0, 0, w, h);
    const blob = await canvasToBlob(canvas, 'image/webp', 0.82);
    if (!blob) return file;
    if (blob.size >= file.size * 0.95) return file;
    return new File([blob], buildWebpName(file.name), { type: 'image/webp', lastModified: Date.now() });
  } catch (e) {
    return file;
  }
}

// ── 通用附件选择器 ──
let _attachmentPickerCb = null;
let _selectedAttachmentUrl = null;

function openAttachmentPicker(cb, opts = {}) {
  _attachmentPickerCb = cb;
  _selectedAttachmentUrl = null;
  const modal = document.getElementById('attachmentPicker');
  if (!modal) return;
  modal.style.display = 'flex';
  
  // 重置确认按钮状态
  const confirmBtn = document.getElementById('confirmAttachmentBtn');
  if (confirmBtn) {
    confirmBtn.disabled = true;
    confirmBtn.style.opacity = '0.5';
  }
  
  loadAttachmentList(opts.accept || 'all');
}

function closeAttachmentPicker() {
  const modal = document.getElementById('attachmentPicker');
  if (modal) modal.style.display = 'none';
}

function handleAttachmentSelect(el, url) {
  // 移除之前的所有选中状态
  document.querySelectorAll('.media-grid-item').forEach(item => {
    item.classList.remove('selected');
  });
  
  // 选中当前项
  el.classList.add('selected');
  _selectedAttachmentUrl = url;
  
  // 启用确认按钮
  const confirmBtn = document.getElementById('confirmAttachmentBtn');
  if (confirmBtn) {
    confirmBtn.disabled = false;
    confirmBtn.style.opacity = '1';
  }
}

function confirmAttachmentSelection() {
  if (!_selectedAttachmentUrl) {
    if (typeof showToast === 'function') showToast('请先选择一个文件', 'error');
    return;
  }
  if (typeof _attachmentPickerCb === 'function') {
    _attachmentPickerCb(_selectedAttachmentUrl);
    closeAttachmentPicker();
    if (typeof showToast === 'function') showToast('图片插入成功');
  } else {
    console.error('Attachment picker callback is not a function');
    if (typeof showToast === 'function') showToast('配置错误，请刷新页面', 'error');
  }
}
async function loadAttachmentList(type = 'all', keyword = '') {
  const grid = document.getElementById('attachmentPickerGrid');
  grid.innerHTML = '加载中...';
  const q = new URLSearchParams({ type, keyword, limit: '60' }).toString();
  const r = await fetch('/admin/media/list?' + q);
  const d = await r.json();
  if (!d.ok) { grid.innerHTML = '加载失败'; return; }
  grid.innerHTML = '';
  d.items.forEach(it => {
    const el = document.createElement('div');
    el.className = 'media-grid-item';
    el.style.cursor = 'pointer';
    el.onclick = () => handleAttachmentSelect(el, it.path);
    // 双击直接确认
    el.ondblclick = () => {
      handleAttachmentSelect(el, it.path);
      confirmAttachmentSelection();
    };
    if (it.fileType === 'image') {
      const img = document.createElement('img');
      img.src = it.path; img.className = 'media-grid-thumb';
      el.appendChild(img);
    } else {
      const icon = document.createElement('div');
      icon.className = 'media-grid-icon';
      icon.textContent = '📦';
      el.appendChild(icon);
    }
    grid.appendChild(el);
  });
  if (!d.items.length) grid.innerHTML = '<div style="grid-column: 1 / -1; padding: 60px 20px; text-align: center; color: var(--text-tertiary); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; background: rgba(0,0,0,0.02); border-radius: 12px; border: 1px dashed var(--border-color);"><div style="font-size: 48px; opacity: 0.6;">📭</div><div style="font-size: 14px; font-weight: 500;">暂无文件</div><div style="font-size: 13px; opacity: 0.8;">您可以点击右上方的「上传新文件」按钮添加文件</div></div>';
}
async function doAttachmentUpload(files) {
  const list = Array.from(files || []);
  if (!list.length) return;
  const text = document.getElementById('attachmentUploadText');
  for (const f of list) {
    const uploadFile = await compressImageBeforeUpload(f);
    text.textContent = '正在上传：' + f.name;
    const fd = new FormData(); fd.append('file', uploadFile);
    const r = await fetch('/admin/media/upload', { method: 'POST', body: fd });
    const d = await r.json();
    if (d.ok && _attachmentPickerCb) { 
      if (typeof showToast === 'function') showToast('上传成功');
      _attachmentPickerCb(d.url); 
      closeAttachmentPicker(); 
    }
  }
  text.textContent = '';
}

// ── CSRF Auto-injection ──
(function() {
  const token = document.querySelector('meta[name="csrf-token"]')?.content;
  if (!token) return;

  // For native forms
  const injectToken = (form) => {
    if (form.method.toUpperCase() === 'POST' && !form.querySelector('input[name="_csrf"]')) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = '_csrf';
      input.value = token;
      form.appendChild(input);
    }
  };

  document.querySelectorAll('form').forEach(injectToken);
  
  // For dynamically added forms
  const observer = new MutationObserver((mutations) => {
    mutations.forEach(m => {
      m.addedNodes.forEach(node => {
        if (node.tagName === 'FORM') injectToken(node);
        else if (node && node.querySelectorAll) node.querySelectorAll('form').forEach(injectToken);
      });
    });
  });
  observer.observe(document.body, { childList: true, subtree: true });

  // For fetch calls
  const originalFetch = window.fetch;
  window.fetch = function(url, options = {}) {
    if (options.method && options.method.toUpperCase() !== 'GET') {
      options.headers = options.headers || {};
      if (options.headers instanceof Headers) {
        options.headers.set('X-CSRF-Token', token);
      } else {
        options.headers['X-CSRF-Token'] = token;
      }
    }
    return originalFetch.call(this, url, options);
  };
})();
</script>

