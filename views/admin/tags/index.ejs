<% const activePage = 'tags' %>
<%- include('../partials/layout-head') %>

<style>
@media(min-width:900px){ .tag-layout{ grid-template-columns:280px 1fr !important; } }
</style>

<div class="tag-layout" style="display:grid;grid-template-columns:1fr;gap:20px;">

  <!-- Create form -->
  <div class="cat-form-card">
    <div class="cat-form-header">🏷️ 新建标签</div>
    <div class="cat-form-body">
      <form method="POST" action="/admin/tags">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label">标签名称 <span style="color:var(--admin-red);">*</span></label>
          <input type="text" name="name" class="form-control form-control-sm"
            placeholder="输入标签名称" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">+ 创建标签</button>
      </form>
    </div>
  </div>

  <!-- Tag cloud -->
  <div class="table-card">
    <div class="table-card-header">
      <span class="table-card-title">🏷️ 标签列表</span>
      <span class="badge"><%= tags.length %> 个</span>
    </div>
    <div class="tag-cloud-wrap">
      <% if (tags.length === 0) { %>
      <p class="text-tertiary text-sm" style="padding:8px;">暂无标签，去新建一个吧</p>
      <% } %>
      <% tags.forEach(tag => { %>
      <div class="tag-pill">
        <a href="/tag/<%= tag.slug %>" target="_blank" style="color:var(--text-primary);text-decoration:none;font-weight:500;">
          # <%= tag.name %>
        </a>
        <span class="tag-pill-count"><%= tag.articles ? tag.articles.length : 0 %></span>
        <button class="tag-pill-btn edit" title="编辑"
          onclick="openEditTagModal(<%= tag.id %>, '<%= tag.name.replace(/'/g, "\\'") %>')">✏️</button>
        <form action="/admin/tags/<%= tag.id %>?_method=DELETE" method="POST" style="display:inline;"
          onsubmit="return confirm('确定删除标签「<%= tag.name %>」吗？')">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="tag-pill-btn del" title="删除">✕</button>
        </form>
      </div>
      <% }) %>
    </div>
  </div>

</div>

<!-- Edit tag modal -->
<div class="modal-overlay" id="editTagModal" style="display:none;">
  <div class="modal-box" style="max-width:360px;">
    <div class="modal-header">
      <div class="modal-title">✏️ 编辑标签</div>
      <button class="modal-close" onclick="closeModal('editTagModal')">×</button>
    </div>
    <form id="editTagForm" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">标签名称</label>
          <input type="text" name="name" id="editTagName" class="form-control" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('editTagModal')">取消</button>
        <button type="submit" class="btn btn-primary">保存</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEditTagModal(id, name) {
  document.getElementById('editTagForm').action = `/admin/tags/${id}?_method=PUT`;
  document.getElementById('editTagName').value = name;
  document.getElementById('editTagModal').style.display = 'flex';
  openModal('editTagModal');
}
</script>

<%- include('../partials/layout-foot') %>
